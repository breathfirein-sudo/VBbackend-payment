generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int             @id @default(autoincrement())
  email            String          @unique
  name             String?
  password         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  referralCount    Int             @default(0)
  kycDocName       String?
  kycDocType       String?
  kycDocument      String?
  kycStatus        String          @default("Pending")
  kycUploadedAt    String?
  isUnlocked       Boolean         @default(false)
  resetToken       String?
  resetTokenExpiry DateTime?
  phone            String?
  manualDeposits   ManualDeposit[]
  payments         Payment[]
  positions        Position[]
  trades           Trade[]
  transactions     Transaction[]
  wallet           Wallet?
}

model Wallet {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  balance      Float    @default(0)
  lockedAmount Float    @default(0)
  totalPnl     Float    @default(0)
  winRate      Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}

model Trade {
  id              Int       @id @default(autoincrement())
  userId          Int
  asset           String
  side            String
  amount          Float
  quantity        Float
  leverage        Int
  entryPrice      Float
  exitPrice       Float?
  grossPnl        Float?
  netPnl          Float?
  fee             Float
  gst             Float
  status          String
  durationSeconds Int
  openedAt        DateTime  @default(now())
  closedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  position        Position?
  user            User      @relation(fields: [userId], references: [id])
}

model Position {
  id         Int       @id @default(autoincrement())
  tradeId    Int       @unique
  openPrice  Float
  closePrice Float?
  quantity   Float
  side       String
  status     String
  openedAt   DateTime  @default(now())
  closedAt   DateTime?
  userId     Int?
  trade      Trade     @relation(fields: [tradeId], references: [id])
  user       User?     @relation(fields: [userId], references: [id])
}

model Candle {
  id        Int      @id @default(autoincrement())
  asset     String
  time      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  createdAt DateTime @default(now())
}

model MarketTick {
  id        Int      @id @default(autoincrement())
  asset     String
  timestamp DateTime
  price     Float
  volume    Float
  createdAt DateTime @default(now())
}

model Transaction {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  asset     String
  amount    Float
  fee       Float?
  gst       Float?
  details   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Payment {
  id                    String   @id @default(uuid())
  userId                Int
  orderId               String   @unique
  paymentId             String?
  razorpaySignature     String?
  amount                Float
  currency              String   @default("INR")
  status                String   @default("created")
  paymentMethod         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  accountHolder         String?
  availableBalanceAfter Float?
  bankAccount           String?
  bankName              String?
  ifsc                  String?
  upiId                 String?
  user                  User     @relation(fields: [userId], references: [id])
}

model SupportExecutive {
  id             Int             @id @default(autoincrement())
  name           String
  phone          String?
  email          String?
  role           String
  salary         Float
  status         String          @default("Active")
  shift          String          @default("Day")
  languages      String          @default("English, Hindi")
  rating         Float           @default(5.0)
  experienceYrs  Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  password       String?
  attendance     String          @default("[]")
  settings       String          @default("{}")
  manualDeposits ManualDeposit[]
}

model SupportMessage {
  id        Int      @id @default(autoincrement())
  sender    String
  userEmail String
  execId    Int?
  text      String
  createdAt DateTime @default(now())
  mediaUrl  String?
}

model CallRequest {
  id        Int      @id @default(autoincrement())
  userEmail String
  userName  String
  phone     String
  execId    Int?     // assigned executive ID
  status    String   @default("Pending")
  createdAt DateTime @default(now())
}

model SupportSession {
  id         Int       @id @default(autoincrement())
  userEmail  String    @unique
  execId     Int?      // assigned executive ID
  status     String    @default("Pending") // 'Pending', 'Active', 'Resolved'
  assignedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model ManualDeposit {
  id            Int               @id @default(autoincrement())
  userId        Int
  amount        Float
  utrNumber     String            @unique
  screenshotUrl String?
  status        String            @default("Pending")
  execId        Int?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  paymentMethod String?
  notes         String?
  reviewedBy    SupportExecutive? @relation(fields: [execId], references: [id])
  user          User              @relation(fields: [userId], references: [id])
}

model contest_participants {
  email          String           @id @db.VarChar(255)
  name           String           @db.VarChar(255)
  balance        Decimal?         @default(11000.00) @db.Decimal(18, 2)
  total_trades   Int?             @default(0)
  profit_trades  Int?             @default(0)
  loss_trades    Int?             @default(0)
  success_rate   Decimal?         @default(0.00) @db.Decimal(5, 2)
  registered_at  DateTime?        @default(now()) @db.Timestamp(6)
  contest_trades contest_trades[]
}

model contest_trades {
  id                   Int                  @id @default(autoincrement())
  user_email           String               @db.VarChar(255)
  symbol               String               @db.VarChar(50)
  price                Decimal              @db.Decimal(18, 8)
  quantity             Decimal              @db.Decimal(18, 8)
  type                 String               @db.VarChar(10)
  status               String?              @default("OPEN") @db.VarChar(10)
  entry_amount         Decimal              @db.Decimal(18, 2)
  expiry_time          DateTime             @db.Timestamp(6)
  close_price          Decimal?             @db.Decimal(18, 8)
  pnl                  Decimal?             @default(0.00) @db.Decimal(18, 2)
  timestamp            DateTime?            @default(now()) @db.Timestamp(6)
  contest_participants contest_participants @relation(fields: [user_email], references: [email], onDelete: Cascade, onUpdate: NoAction)
}

model trades {
  id                    Int       @id @default(autoincrement())
  symbol                String    @db.VarChar(10)
  price                 Decimal   @db.Decimal(10, 2)
  quantity              Decimal   @db.Decimal(10, 4)
  type                  String    @db.VarChar(4)
  timestamp             DateTime? @default(now()) @db.Timestamp(6)
  status                String?   @default("OPEN") @db.VarChar(10)
  expiry_time           DateTime? @db.Timestamp(6)
  close_price           Decimal?  @db.Decimal(10, 2)
  user_email            String?   @db.VarChar(255)
  investment_amount     Decimal?  @default(0.00) @db.Decimal(18, 2)
  pnl                   Decimal?  @default(0.00) @db.Decimal(18, 2)
  trade_stake           Decimal?  @default(10.00) @db.Decimal(10, 2)
  application_fee       Decimal?  @default(1.00) @db.Decimal(10, 2)
  returned_amount       Decimal?  @default(0.00) @db.Decimal(10, 2)
  profit_loss_amount    Decimal?  @default(0.00) @db.Decimal(10, 2)
  user_id               Int?
  wallet_balance_before Decimal?  @default(0.00) @db.Decimal
  wallet_balance_after  Decimal?  @default(0.00) @db.Decimal
}
