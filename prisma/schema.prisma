generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  name         String?
  phone        String?
  password     String?
  wallet       Wallet?
  trades       Trade[]
  positions    Position[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  payments     Payment[]
  manualDeposits ManualDeposit[]
  referralCount Int           @default(0)
  isUnlocked   Boolean       @default(false)
  kycStatus    String        @default("Pending")
  kycDocument  String?       @db.Text
  kycDocName   String?
  kycDocType   String?
  kycUploadedAt String?
  resetToken       String?
  resetTokenExpiry DateTime?
}

model Wallet {
  id           Int      @id @default(autoincrement())
  user         User     @relation(fields: [userId], references: [id])
  userId       Int      @unique
  balance      Float    @default(0)
  lockedAmount Float    @default(0)
  totalPnl     Float    @default(0)
  winRate      Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Trade {
  id              Int       @id @default(autoincrement())
  user            User      @relation(fields: [userId], references: [id])
  userId          Int
  asset           String
  side            String
  amount          Float
  quantity        Float
  leverage        Int
  entryPrice      Float
  exitPrice       Float?
  grossPnl        Float?
  netPnl          Float?
  fee             Float
  gst             Float
  status          String
  durationSeconds Int
  openedAt        DateTime  @default(now())
  closedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  position        Position?
}

model Position {
  id         Int       @id @default(autoincrement())
  trade      Trade     @relation(fields: [tradeId], references: [id])
  tradeId    Int       @unique
  openPrice  Float
  closePrice Float?
  quantity   Float
  side       String
  status     String
  openedAt   DateTime  @default(now())
  closedAt   DateTime?
  user       User?     @relation(fields: [userId], references: [id])
  userId     Int?
}

model Candle {
  id        Int      @id @default(autoincrement())
  asset     String
  time      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  createdAt DateTime @default(now())
}

model MarketTick {
  id        Int      @id @default(autoincrement())
  asset     String
  timestamp DateTime
  price     Float
  volume    Float
  createdAt DateTime @default(now())
}

model Transaction {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  type      String
  asset     String
  amount    Float
  fee       Float?
  gst       Float?
  details   String?
  createdAt DateTime @default(now())
}

model Payment {
  id                    String   @id @default(uuid())
  user                  User     @relation(fields: [userId], references: [id])
  userId                Int
  orderId               String   @unique
  paymentId             String?
  razorpaySignature     String?
  amount                Float
  currency              String   @default("INR")
  status                String   @default("created")
  paymentMethod         String?
  upiId                 String?
  bankAccount           String?
  ifsc                  String?
  bankName              String?
  accountHolder         String?
  availableBalanceAfter Float?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model SupportExecutive {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String?
  email         String?
  password      String?
  attendance    String   @default("[]")
  role          String   // 'Chat', 'Call', 'Both'
  salary        Float
  status        String   @default("Active") // 'Active', 'Inactive'
  shift         String   @default("Day") // 'Day', 'Night', 'Rotational'
  languages     String   @default("English, Hindi")
  rating        Float    @default(5.0)
  experienceYrs Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  manualDeposits ManualDeposit[]
}

model SupportMessage {
  id        Int      @id @default(autoincrement())
  sender    String   // 'user' or 'executive'
  userEmail String
  execId    Int?
  text      String
  createdAt DateTime @default(now())
}

model CallRequest {
  id        Int      @id @default(autoincrement())
  userEmail String
  userName  String
  phone     String
  status    String   @default("Pending") // 'Pending', 'Connected', 'Closed'
  createdAt DateTime @default(now())
}

model ManualDeposit {
  id            Int      @id @default(autoincrement())
  user          User     @relation(fields: [userId], references: [id])
  userId        Int
  amount        Float
  utrNumber     String   @unique
  screenshotUrl String?
  status        String   @default("Pending") // 'Pending', 'Approved', 'Rejected'
  reviewedBy    SupportExecutive? @relation(fields: [execId], references: [id])
  execId        Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
